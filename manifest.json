{
  "manifest_version": 3,
  "name": "Gemini Meeting Recorder & Summarizer",
  "version": "1.0.0",
  "description": "Record meetings, transcribe live via WebSocket STT, and summarize with Gemini using strict JSON Mode and Rolling Chunking.",
  "permissions": [
    "storage",
    "activeTab",
    "tabCapture",
    "offscreen",
    "alarms",
    "microphone"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://meet.google.com/*",
    "https://teams.microsoft.com/*",
    "https://*.zoom.us/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Gemini Recorder Settings"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://teams.microsoft.com/*",
        "https://*.zoom.us/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "services/db.js",
        "content/content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "services/db.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
